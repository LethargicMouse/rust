---- lex -------------------------------

fn lex(source) vec<token> {
  let lexer = new_lexer(source);
  loop if lexer.lex_finished()
      do break
    else lexer.step();
  lexer.res
}

fn new_lexer(source) lexer {
  lexer {
    res: empty_vec()
  }.after(skip)
}

fn skip(&lexer)
  do loop {
    skip_space();
    if see_line_comment()
      do skip_line_comment()
    else break;
  }

fn step(&lexer)
  do todo("lex step");

fn lex_finished(lexer) bool
  do lexer.index == lexer.source.code.size;

struct lexer {
  res: vec<token>,
}

struct token { lexeme, location }

enum lexeme {
  simple_lexeme(-),
}

enum simple_lexeme {
  eof,
}


---- source ----------------------------

fn source_from(path) source
  do source {}

struct source {}

struct location {}


---- goodc args ------------------------

struct goodc_args { command, options }

enum command {
  clean_command,
  run_command(path),
}

struct options {
  passed: args
}

fn parse_args(args) goodc_args 
  do goodc_args {
    command: parse_command(args),
    options: parse_options(args)
  }

fn parse_command(&args) command
  do args.next().match {
    some(arg) => 
      if arg.eq("clean".ptr) 
        do clean_command
      else if arg.eq("run".ptr)
        do parse_path(args).run_command()
      else unexpected("command", arg).die(),
    none => expected("command").die() 
  }

fn parse_path(&args) path
  do args.next().match {
    some(path) => path,
    none => expected("path").die()
  }

fn parse_options(args) options {
  let options = default_options();
  loop args.next().match {
    none => break,
    some(arg) =>
      if arg.eq("--".ptr) {
        options.passed = args; 
        break;
      }
      else unexpected("argument", arg).die()
  }
  options
}

fn default_options() options
  do options {
    passed: []
  }


---- goodc args error ------------------

struct unexpected { str, cstr }

fn unexpected(str, cstr) unexpected
  do unexpected { str, cstr }

impl display for unexpected {
  fn wprint<w: writer>(w, self) {
    w.wprint(args_error);
    w.wprint("unexpected ");
    w.wprint(self.str);
    w.wprint(": ");
    w.wprint(self.cstr);
  }
}

let args_error: str = "! error reading args: ";

struct expected { str }

fn expected(str) expected
  do expected { str }

impl display for expected {
  fn wprint<w: writer>(w, self) {
    w.wprint(args_error);
    w.wprint("expected ");
    w.wprint(self.str)
  }
}

---- args ------------------------------

struct cargs { size, *cstr }

type args = [cstr];

impl better<cargs> for args {
  fn better(cargs) args
    do args {
      ptr: cargs.ptr + 1,
      size: cargs.size - 1
    } -- skip exec name
}


---- fs --------------------------------

type path = cstr;

struct file { fd }

impl writer for file {
  fn wwrite(self, str)
    do write(self.fd, str.ptr, str.size);
}

type fd = i32;

let  stdin: file = file { fd: 0 };
let stdout: file = file { fd: 1 };
let stderr: file = file { fd: 2 };

type file_mode = i32;

let write_mode: file_mode = 1;

fn create_file(path) file
  do file {
    fd: open(path, write_mode)
  }


---- str -------------------------------

type cstr = *u8;

impl eq for cstr {
  fn eq(self, other: self) bool
    do strcmp(self, other) == 0;
}

type str = [u8];

impl better<cstr> for str {
  fn better(cstr) str
    do str {
      ptr: cstr,
      size: strlen(cstr)
    }
}

impl display for str {
  fn wprint<w: writer>(w, self)
    do w.wwrite(self);
}

impl display for cstr {
  fn wprint<w: writer>(w, self)
    do w.wwrite(better(self));
}


---- slice -----------------------------

fn drop<t>(&[t], size) {
  slice.ptr += 1;
  slice.size -= 1;
}

impl<t> iterator<t> for [t] {
  fn next(&self) maybe<t>
    do if self.size == 0
      do none
    else {
      let res = *self.ptr;
      self.drop(1);
      some(res)
    }
}


---- num -------------------------------

type size = u64;
type index = size;


---- display ---------------------------

trait display {
  fn wprint<w: writer>(w, self);
}

fn wprintln<w: writer, s: display>(w, s) {
  w.wprint(s);
  w.wprint("\n");
}

fn wprint_to<w: writer, s: display>(s, w)
  do w.wprint(s);

fn println<s: display>(s)
  do stdout.wprintln(s);


