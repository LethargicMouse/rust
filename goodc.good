fn void<t>(t) {}


---- vec -------------------------------

struct vec<t> { *t, cap: size, size }

fn empty_vec<t>() vec<t>
  do vec { ptr: 0, cap: 0, size: 0 }


---- process ---------------------------

fn call(str)
  do system(str.ptr).void();


---- fn --------------------------------

fn after<t>(t, fn(&t)) t {
  fn(t);
  t
}
