fn main(cargs) {
  let args: args = better(cargs);
  let args = parse_args(args);
  args.command.match {
    clean_command => clean(),
    run_command(path) => run_file(path),
  }
}

fn clean()
  do call("rm out.qbe out.s out");

fn run_file(path) {
  make(path);
  run_out();
}

fn make(path) {
  compile(path);
  run_qbe();
  run_cc();
}

fn run_qbe()
  do call("qbe -o out.s out.qbe");

fn run_cc()
  do call("cc -o out out.s");

fn run_out()
  do call("./out");

fn compile(path) 
  do source_from(path)
    .lex()
    .parse()
    .analyse()
    .gen_ir();


---- goodc codegen ---------------------

fn gen_ir(cast) {
  let out = create_file("out.qbe".ptr);
  ir_gener { cast, out }.run().wprint_to(out);
}

fn run(ir_gener) ir
  do todo("run ir_gener");

struct ir_gener { cast, out: file }

