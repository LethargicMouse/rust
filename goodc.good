---- error -----------------------------

fn die<e: display, t>(e) t {
  eprintln(e);
  exit(1)
}

fn eprintln<e: display>(e)
  do stderr.wprintln(e);

fn todo<t>(str) t
  do die(not_implemented(str));

struct not_implemented { str }

fn not_implemented(str) not_implemented
  do not_implemented { str }

impl display for not_implemented {
  fn wprint<w: writer>(w, self) {
    w.wprint("! not yet implemented: ");
    w.wprint(self.str);
  }
}


